# Integra Analytics Backend — Environment Variables (EXAMPLE)
# Copy file ini ke .env dan isi value asli.
# .env sudah di-gitignore, aman.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json

# AI Config Encryption — Generate dengan: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# JANGAN commit key ini ke git. Simpan di .env.
AI_MASTER_KEY=

CORS_ORIGINS=["http://localhost:3000"]
DEBUG=false
HOST=0.0.0.0
PORT=8000
